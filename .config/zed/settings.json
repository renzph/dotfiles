// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "helix_mode": true,
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "agent": {
    "dock": "left",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "right"
  },
  "tab_bar": {
    "show": true,
  },
  "disable_ai": false,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "project_panel": {
    "dock": "right",
    "show_diagnostics": "all",
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "all",
  },
  "diagnostics": { "inline": { "enabled": true } },
  "diagnostics_max_severity": null,
  "vim_mode": false,
  "base_keymap": "VSCode",
  "ui_font_size": 14.0,
  "buffer_font_size": 12.0,
  "theme": "Tokyo Night",
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
  },
  "languages": {
    "Rust": {
      "prettier": {
        "allowed": true,
      },
      "inlay_hints": {
        "show_background": true,
      },
      "preferred_line_length": 120,
    },
    "Python": {
      "tab_size": 3,
      "language_servers": ["pyright", "ruff", "pylsp"],
      "format_on_save": "on",
      "formatter": "language_server",
    },
    "Haskell": {
      "format_on_save": "on",
      "inlay_hints": { "enabled": true },
    },
  },
  "terminal": {
    "detect_venv": {
      "on": {
        "directories": [".venv", "apps/backend/.venv"],
      },
    },
  },
}
